# Copy this file to .env and fill in your keys. .env is gitignored -- never commit secrets.

# --- Alpaca (free paper trading + IEX market data) ---------------------------------
# Get free keys at https://alpaca.markets/ -> sign up -> "Paper Trading" -> generate keys.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# true = paper-trading endpoint (safe, fake money). Set to false ONLY for real money.
ALPACA_PAPER=true
# "iex" = free single-venue feed. "sip" = full-market consolidated tape (paid plan).
ALPACA_DATA_FEED=iex

# --- Charles Schwab (REAL MONEY ONLY -- there is no usable paper/sandbox) -----------
# Only needed when you migrate to live trading on Schwab. Requires a Schwab brokerage
# account + a developer app approved at https://developer.schwab.com/ (a few business days).
# Install the optional dependency first:  uv sync --extra schwab
SCHWAB_API_KEY=
SCHWAB_APP_SECRET=
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
SCHWAB_TOKEN_PATH=.schwab_token.json
